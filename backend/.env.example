# Use an HTTPS endpoint in production. Do not commit the real client secret.
ANANTA_BASE_URL=https://ananta.example.edu/framework
ANANTA_CLIENT_SECRET=

# Comma-separated browser origins permitted to call this API.
CIC_ALLOWED_ORIGINS=https://cic.example.edu

CIC_MAX_TEAM_PHOTO_SIZE_BYTES=204800
CIC_MAX_TENDER_PDF_SIZE_BYTES=26214400
ANANTA_SESSION_TIMEOUT_SECONDS=5
ANANTA_LOGIN_TIMEOUT_SECONDS=8
